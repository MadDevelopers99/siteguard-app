<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Team Settings — SiteGuard</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/team-sidebar', { active: 'settings' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Settings</h1>
    </div>
    <p style="color:var(--steel); margin:-14px 0 20px; font-size:14px;">
      These dropdown option lists are currently fixed in the app's code rather than editable here.
      If you need a value added or changed, let the developer know and it can be updated quickly.
    </p>

    <% const lists = [
      ['Driver Roles', DRIVER_ROLES],
      ['Employment Types', EMPLOYMENT_TYPES],
      ['Driver Statuses', DRIVER_STATUS_OPTIONS],
      ['Vehicle Types', VEHICLE_TYPES],
      ['Vehicle Statuses', VEHICLE_STATUSES],
      ['Team Statuses', TEAM_STATUSES],
      ['Vacation Types', VACATION_TYPES],
      ['Absence Types', ABSENCE_TYPES],
      ['Document Categories', DOCUMENT_CATEGORIES],
      ['Work Areas', WORK_AREAS]
    ]; %>
    <% lists.forEach(([title, values]) => { %>
      <div class="admin-card">
        <h3><%= title %></h3>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <% values.forEach(v => { %><span class="badge badge-confirmed"><%= v %></span><% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</div>
</body>
</html>
