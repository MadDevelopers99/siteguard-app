<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Item List — SiteGuard Inventory</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'inv-items' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Item List</h1>
      <a class="btn btn-sm" style="text-decoration:none;" href="/admin/inventory/items/new">+ Add Item</a>
    </div>

    <form class="filter-bar" method="GET" action="/admin/inventory/items">
      <input type="text" name="q" placeholder="Search name or article #…" value="<%= filters.q %>">
      <select name="category">
        <option value="">All categories</option>
        <% categories.forEach(c => { %><option value="<%= c %>" <%= filters.category === c ? 'selected' : '' %>><%= c %></option><% }) %>
      </select>
      <select name="status">
        <option value="">All statuses</option>
        <% INVENTORY_ITEM_STATUSES.forEach(s => { %><option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option><% }) %>
      </select>
      <button class="btn btn-outline btn-sm" type="submit">Filter</button>
    </form>

    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Item ID</th><th>Item Name</th><th>Category</th><th>Current</th><th>Reserved</th>
            <th>Available</th><th>Damaged</th><th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (items.length === 0) { %>
            <tr><td colspan="8" style="text-align:center; color:#8a8f90;">No items match these filters.</td></tr>
          <% } %>
          <% items.forEach(i => { %>
            <tr onclick="window.location='/admin/inventory/items/<%= i.id %>'" style="cursor:pointer;">
              <td><%= displayItemId(i.id) %></td>
              <td><%= i.item_name %></td>
              <td><%= i.category || '—' %></td>
              <td><%= i.available_stock %> <%= i.unit %></td>
              <td><%= i.reserved_qty || 0 %></td>
              <td><%= (i.available_stock - (i.reserved_qty || 0) - (i.damaged_qty || 0)).toFixed(0) %></td>
              <td><%= i.damaged_qty || 0 %></td>
              <td><span class="badge badge-<%= statusBadgeClass(i.status) %>"><%= i.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
