<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventory Settings — SiteGuard</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'inv-settings' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Inventory Settings</h1>
    </div>
    <p style="color:var(--steel); margin:-14px 0 20px; font-size:14px;">
      These dropdown option lists are currently fixed in the app's code rather than editable here.
    </p>

    <% const lists = [
      ['Item Statuses', INVENTORY_ITEM_STATUSES],
      ['Stock In Source Types', STOCK_IN_SOURCE_TYPES],
      ['Stock Out Reason Types', STOCK_OUT_REASON_TYPES],
      ['Stock Adjustment Reasons', STOCK_ADJUSTMENT_REASONS],
      ['Damaged / Missing Types', DAMAGED_MISSING_TYPES],
      ['Damaged / Missing Statuses', DAMAGED_MISSING_STATUSES],
      ['Stock Count Statuses', STOCK_COUNT_STATUSES]
    ]; %>
    <% lists.forEach(([title, values]) => { %>
      <div class="admin-card">
        <h3><%= title %></h3>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <% values.forEach(v => { %><span class="badge badge-confirmed"><%= v %></span><% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</div>
</body>
</html>
