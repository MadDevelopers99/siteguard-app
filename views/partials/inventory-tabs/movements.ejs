<div class="admin-card">
  <h3>Stock In</h3>
  <form method="POST" action="/admin/inventory/items/<%= item.id %>/stock-in" class="form-grid">
    <div class="form-group"><label>Quantity</label><input type="number" step="0.1" name="quantity" required></div>
    <div class="form-group">
      <label>Source Type</label>
      <select name="source_type">
        <% STOCK_IN_SOURCE_TYPES.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><label>Source Reference</label><input type="text" name="source_reference"></div>
    <div class="form-group"><label>Storage Location</label><input type="text" name="storage_location" value="<%= item.storage_location || '' %>"></div>
    <div class="form-group full"><label>Notes</label><input type="text" name="notes"></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Confirm Stock In</button></div>
  </form>
</div>

<div class="admin-card">
  <h3>Stock Out</h3>
  <form method="POST" action="/admin/inventory/items/<%= item.id %>/stock-out" class="form-grid">
    <div class="form-group"><label>Quantity</label><input type="number" step="0.1" name="quantity" required></div>
    <div class="form-group">
      <label>Reason</label>
      <select name="reason">
        <% STOCK_OUT_REASON_TYPES.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><label>Reference</label><input type="text" name="source_reference"></div>
    <div class="form-group full"><label>Notes</label><input type="text" name="notes"></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Confirm Stock Out</button></div>
  </form>
</div>

<div class="admin-card">
  <h3>Stock Adjustment</h3>
  <form method="POST" action="/admin/inventory/items/<%= item.id %>/adjust" class="form-grid">
    <div class="form-group"><label>New Quantity (current: <%= item.available_stock %>)</label><input type="number" step="0.1" name="new_quantity" required></div>
    <div class="form-group">
      <label>Reason</label>
      <select name="reason">
        <% STOCK_ADJUSTMENT_REASONS.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
      </select>
    </div>
    <div class="form-group full"><label>Notes</label><input type="text" name="notes"></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Create Adjustment</button></div>
  </form>
</div>

<div class="admin-card">
  <h3>Movement Log</h3>
  <div class="data-table-wrap">
    <table class="data-table">
      <thead><tr><th>Date</th><th>Type</th><th>Qty</th><th>Source</th><th>Reference</th><th>By</th></tr></thead>
      <tbody>
        <% if (movements.length === 0) { %>
          <tr><td colspan="6" style="text-align:center; color:#8a8f90;">No movements yet.</td></tr>
        <% } %>
        <% movements.forEach(m => { %>
          <tr>
            <td><%= m.date %></td>
            <td><%= m.movement_type %></td>
            <td><%= m.movement_type === 'out' ? '-' : '+' %><%= Math.abs(m.quantity) %></td>
            <td><%= m.source_type || '—' %></td>
            <td><%= m.source_reference || '—' %></td>
            <td><%= m.created_by || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
