<div class="driver-card">
  <h3>Inventory Report</h3>
  <% if (inventoryRows.length === 0) { %>
    <p style="color:#8a8f90;">No inventory listed for this task.</p>
  <% } else { %>
    <form method="POST" action="/driver/tasks/<%= task.order_id %>/inventory-report">
      <% inventoryRows.forEach(r => { %>
        <div class="driver-field">
          <label><%= r.item_name %> — Loaded/Expected: <%= r.loaded_qty ?? r.main_admin_approved_qty ?? r.planned_qty %> <%= r.unit %></label>
          <input type="hidden" name="item_id" value="<%= r.id %>">

          <% if (flags.inventoryReportType === 'used_returned_damaged_missing' || flags.inventoryReportType === 'used_returned_exchanged_damaged') { %>
            <div style="display:flex; gap:6px; margin-bottom:6px;">
              <input type="number" step="0.1" name="used_qty" value="<%= r.used_qty ?? '' %>" placeholder="Used">
              <input type="number" step="0.1" name="returned_qty" value="<%= r.returned_qty ?? '' %>" placeholder="Returned">
              <input type="number" step="0.1" name="damaged_qty" value="<%= r.damaged_qty ?? '' %>" placeholder="Damaged">
              <% if (flags.inventoryReportType === 'used_returned_damaged_missing') { %>
                <input type="number" step="0.1" name="missing_qty" value="<%= r.missing_qty ?? '' %>" placeholder="Missing">
              <% } %>
            </div>
          <% } else if (flags.inventoryReportType === 'picked_damaged_missing') { %>
            <div style="display:flex; gap:6px; margin-bottom:6px;">
              <input type="number" step="0.1" name="picked_qty" value="<%= r.picked_qty ?? '' %>" placeholder="Picked">
              <input type="number" step="0.1" name="damaged_qty" value="<%= r.damaged_qty ?? '' %>" placeholder="Damaged">
              <input type="number" step="0.1" name="missing_qty" value="<%= r.missing_qty ?? '' %>" placeholder="Missing">
            </div>
          <% } else if (flags.inventoryReportType === 'returned_damaged_missing') { %>
            <div style="display:flex; gap:6px; margin-bottom:6px;">
              <input type="number" step="0.1" name="returned_qty" value="<%= r.returned_qty ?? '' %>" placeholder="Returned">
              <input type="number" step="0.1" name="damaged_qty" value="<%= r.damaged_qty ?? '' %>" placeholder="Damaged">
              <input type="number" step="0.1" name="missing_qty" value="<%= r.missing_qty ?? '' %>" placeholder="Missing">
            </div>
          <% } else if (flags.inventoryReportType === 'checked_issue_note') { %>
            <input type="text" name="notes" value="<%= r.notes ?? '' %>" placeholder="Checked / issue / note">
          <% } %>
        </div>
      <% }) %>
      <button class="driver-btn-lg" type="submit">Submit Inventory Report</button>
    </form>
  <% } %>
</div>
