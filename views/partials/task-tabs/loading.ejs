<div class="driver-card">
  <h3>Loading</h3>
  <% if (inventoryRows.length === 0) { %>
    <p style="color:#8a8f90;">No inventory listed for this task.</p>
  <% } else { %>
    <form method="POST" action="/driver/tasks/<%= task.order_id %>/loading">
      <% inventoryRows.forEach(r => { %>
        <div class="driver-field">
          <label><%= r.item_name %> — Required: <%= r.main_admin_approved_qty ?? r.planned_qty %> <%= r.unit %></label>
          <input type="hidden" name="item_id" value="<%= r.id %>">
          <input type="number" step="0.1" name="loaded_qty" value="<%= r.loaded_qty ?? '' %>" placeholder="Loaded qty">
        </div>
      <% }) %>
      <button class="driver-btn-lg" type="submit">Confirm Loading Complete</button>
    </form>
  <% } %>
</div>
