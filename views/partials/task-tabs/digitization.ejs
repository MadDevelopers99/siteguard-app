<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="driver-card">
  <h3>Field Digitization</h3>
  <p style="color:#8a8f90; font-size:13px;">Tap "Add Point" / "Draw Line" / "Draw Area" / "Draw Rectangle" first, then tap the map. While a tool is active the map won't pan, so taps register as drawing.</p>

  <div class="digitize-toolbar">
    <button type="button" class="btn btn-outline btn-sm" data-mode="point">Add Point</button>
    <button type="button" class="btn btn-outline btn-sm" data-mode="line">Draw Line</button>
    <button type="button" class="btn btn-outline btn-sm" data-mode="area">Draw Area</button>
    <button type="button" class="btn btn-outline btn-sm" data-mode="rectangle">Draw Rectangle</button>
    <button type="button" class="btn btn-outline btn-sm" id="finishShapeBtn" style="display:none;">Finish Shape</button>
    <button type="button" class="btn btn-outline btn-sm" id="undoBtn">Undo</button>
    <button type="button" class="btn btn-outline btn-sm" id="stopDrawBtn" style="display:none;">Stop Drawing (Pan Map)</button>
  </div>

  <div class="digitize-toolbar" style="margin-top:6px;">
    <span style="font-size:12px; color:#8a8f90; align-self:center;">Templates:</span>
    <button type="button" class="btn btn-outline btn-sm template-btn" data-object-type="Pole">Pole</button>
    <button type="button" class="btn btn-outline btn-sm template-btn" data-object-type="Halteverbot Sign"><img src="/images/signs/haltverbot.svg" alt="" style="width:14px; height:14px; vertical-align:middle; margin-right:3px;">Pole + Sign</button>
    <button type="button" class="btn btn-outline btn-sm template-btn" data-object-type="Base Plate / Standsockel">Base Plate</button>
  </div>

  <div id="mapStatus" style="font-size:12px; color:#8a8f90; margin:6px 0;">Locating…</div>
  <div id="digitizeMap" class="digitize-map"></div>

  <div id="featureForm" class="driver-card" style="display:none; margin-top:10px;">
    <h3>Feature Details</h3>
    <div class="driver-field">
      <label>Object Type</label>
      <div style="display:flex; align-items:center; gap:8px;">
        <select id="featureObjectType" style="flex:1;">
          <% DIGITIZATION_OBJECT_TYPES.forEach(o => { %><option value="<%= o %>"><%= o %></option><% }) %>
        </select>
        <img id="objectTypeIcon" src="" alt="" style="width:28px; height:28px; display:none;">
      </div>
    </div>
    <div class="driver-field">
      <label>Inventory Item</label>
      <select id="featureItem">
        <option value="">— select —</option>
        <% inventoryRows.forEach(r => { %><option value="<%= r.id %>" data-name="<%= r.item_name %>"><%= r.item_name %></option><% }) %>
      </select>
    </div>
    <div class="driver-field"><label>Quantity Used</label><input type="number" step="1" min="1" value="1" id="featureQty"></div>
    <div class="driver-field">
      <label>Condition</label>
      <select id="featureCondition">
        <option value="Good">Good</option>
        <option value="Damaged">Damaged</option>
      </select>
    </div>
    <div class="driver-field"><label>Notes</label><input type="text" id="featureNotes"></div>
    <div style="display:flex; gap:8px;">
      <button type="button" class="driver-btn-lg" id="saveFeatureBtn">Save Feature</button>
      <button type="button" class="driver-btn-lg outline" id="cancelFeatureBtn">Cancel</button>
    </div>
  </div>

  <div id="featureList" style="margin-top:12px;"></div>

  <form method="POST" action="/driver/tasks/<%= task.order_id %>/digitization" id="saveDraftForm" style="margin-top:14px;">
    <input type="hidden" name="features" id="featuresInputDraft">
    <button class="driver-btn-lg outline" type="submit">Save Digitized Map</button>
  </form>
  <form method="POST" action="/driver/tasks/<%= task.order_id %>/digitization/submit" id="submitForm" style="margin-top:8px;">
    <input type="hidden" name="features" id="featuresInputSubmit">
    <button class="driver-btn-lg" type="submit">Submit Digitized Map</button>
  </form>
</div>

<script>
(function () {
  // Fallback center (Munich) used only if the browser has no/denied GPS.
  const FALLBACK_CENTER = [48.1351, 11.5820];

  let features = <%- JSON.stringify(features || []) %>;
  let mode = null;
  let pendingPoints = [];
  let pendingType = null;
  let templateObjectType = null;
  let pendingLayer = null;
  const savedLayers = [];

  let leafletMap = null;
  let locatingStarted = false;
  let mapStarted = false;

  const OBJECT_TYPE_ICONS = {
    'Halteverbot Sign': '/images/signs/haltverbot.svg',
    'Traffic Sign': '/images/signs/arbeitsstelle.svg',
    'Single Barrier': '/images/signs/absperrschranke.svg',
    'Warning Light': '/images/signs/leitbake.svg',
    'Bakenleuchte': '/images/signs/leitbake.svg'
  };

  function updateObjectTypeIcon() {
    const type = document.getElementById('featureObjectType').value;
    const icon = document.getElementById('objectTypeIcon');
    const src = OBJECT_TYPE_ICONS[type];
    if (src) { icon.src = src; icon.style.display = ''; } else { icon.style.display = 'none'; }
  }
  document.getElementById('featureObjectType').addEventListener('change', updateObjectTypeIcon);

  function drawFeature(map, f, color) {
    if (f.type === 'point') {
      return L.circleMarker(f.coords[0], { radius: 6, color, fillColor: color, fillOpacity: 1 })
        .addTo(map)
        .bindTooltip(`${f.objectType || '—'} (${f.itemName || 'no item'} x${f.qty || 0})`);
    }
    if (f.type === 'line') {
      return L.polyline(f.coords, { color, weight: 4 })
        .addTo(map)
        .bindTooltip(`${f.objectType || '—'} (${f.itemName || 'no item'} x${f.qty || 0})`);
    }
    return L.polygon(f.coords, { color, weight: 3, fillOpacity: 0.15 })
      .addTo(map)
      .bindTooltip(`${f.objectType || '—'} (${f.itemName || 'no item'} x${f.qty || 0})`);
  }

  function redrawPending() {
    if (!leafletMap) return;
    if (pendingLayer) { leafletMap.removeLayer(pendingLayer); pendingLayer = null; }
    if (pendingPoints.length === 0) return;
    if (pendingType === 'line') {
      pendingLayer = L.polyline(pendingPoints, { color: '#d98c00', weight: 4, dashArray: '6,6' }).addTo(leafletMap);
    } else if (pendingType === 'area') {
      pendingLayer = L.polygon(pendingPoints, { color: '#d98c00', weight: 3, dashArray: '6,6', fillOpacity: 0.1 }).addTo(leafletMap);
    } else if (pendingType === 'rectangle') {
      if (pendingPoints.length === 1) {
        pendingLayer = L.circleMarker(pendingPoints[0], { radius: 5, color: '#d98c00', fillColor: '#d98c00', fillOpacity: 1 }).addTo(leafletMap);
      } else {
        pendingLayer = L.polygon(pendingPoints, { color: '#d98c00', weight: 3, dashArray: '6,6', fillOpacity: 0.1 }).addTo(leafletMap);
      }
    }
  }

  function renderFeatureList() {
    const list = document.getElementById('featureList');
    if (features.length === 0) { list.innerHTML = '<p style="color:#8a8f90;">No features added yet.</p>'; return; }
    list.innerHTML = '<ul style="margin:0; padding-left:20px; list-style:none;">' + features.map((f, i) => {
      const src = OBJECT_TYPE_ICONS[f.objectType];
      const iconHtml = src ? `<img src="${src}" alt="" style="width:16px; height:16px; vertical-align:middle; margin-right:4px;">` : '';
      return `<li>${iconHtml}${f.objectType || '—'} — ${f.itemName || 'no item'} x${f.qty || 0} <button type="button" class="feature-remove" data-idx="${i}" style="margin-left:8px;">Remove</button></li>`;
    }).join('') + '</ul>';
    list.querySelectorAll('.feature-remove').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.idx, 10);
        if (leafletMap && savedLayers[idx]) { leafletMap.removeLayer(savedLayers[idx]); }
        savedLayers.splice(idx, 1);
        features.splice(idx, 1);
        syncInputs();
        renderFeatureList();
      });
    });
  }

  function syncInputs() {
    document.getElementById('featuresInputDraft').value = JSON.stringify(features);
    document.getElementById('featuresInputSubmit').value = JSON.stringify(features);
  }

  // While a drawing tool is active, the map must NOT pan on touch — otherwise
  // a finger tap that moves even a couple of pixels is treated as a drag and
  // no click ever fires. Dragging is restored the moment drawing stops.
  function enterMode(newMode) {
    mode = newMode;
    pendingPoints = [];
    pendingType = newMode;
    document.getElementById('finishShapeBtn').style.display = newMode === 'line' || newMode === 'area' ? '' : 'none';
    document.getElementById('stopDrawBtn').style.display = '';
    if (leafletMap) {
      if (pendingLayer) { leafletMap.removeLayer(pendingLayer); pendingLayer = null; }
      leafletMap.dragging.disable();
    }
  }

  function exitMode() {
    mode = null;
    pendingPoints = [];
    pendingType = null;
    templateObjectType = null;
    document.getElementById('finishShapeBtn').style.display = 'none';
    document.getElementById('stopDrawBtn').style.display = 'none';
    if (leafletMap) {
      if (pendingLayer) { leafletMap.removeLayer(pendingLayer); pendingLayer = null; }
      leafletMap.dragging.enable();
    }
  }

  document.querySelectorAll('[data-mode]').forEach((btn) => {
    btn.addEventListener('click', () => enterMode(btn.dataset.mode));
  });

  document.getElementById('stopDrawBtn').addEventListener('click', exitMode);

  document.querySelectorAll('.template-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      enterMode('point');
      templateObjectType = btn.dataset.objectType;
    });
  });

  document.getElementById('finishShapeBtn').addEventListener('click', () => {
    if (pendingPoints.length < 2) return;
    openFeatureForm();
  });

  document.getElementById('undoBtn').addEventListener('click', () => {
    if (leafletMap && savedLayers.length > 0) { leafletMap.removeLayer(savedLayers[savedLayers.length - 1]); }
    savedLayers.pop();
    features.pop();
    syncInputs();
    renderFeatureList();
  });

  function openFeatureForm() {
    const form = document.getElementById('featureForm');
    form.style.display = '';
    if (templateObjectType) document.getElementById('featureObjectType').value = templateObjectType;
    updateObjectTypeIcon();
    form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('cancelFeatureBtn').addEventListener('click', () => {
    document.getElementById('featureForm').style.display = 'none';
    exitMode();
  });

  document.getElementById('saveFeatureBtn').addEventListener('click', () => {
    const itemSelect = document.getElementById('featureItem');
    const opt = itemSelect.options[itemSelect.selectedIndex];
    const feature = {
      id: 'f' + Date.now(),
      type: pendingType === 'rectangle' ? 'area' : pendingType,
      objectType: document.getElementById('featureObjectType').value,
      coords: pendingPoints,
      itemId: itemSelect.value || null,
      itemName: opt ? opt.dataset.name : null,
      qty: parseFloat(document.getElementById('featureQty').value) || 0,
      condition: document.getElementById('featureCondition').value,
      notes: document.getElementById('featureNotes').value
    };
    features.push(feature);
    if (leafletMap) {
      if (pendingLayer) { leafletMap.removeLayer(pendingLayer); pendingLayer = null; }
      savedLayers.push(drawFeature(leafletMap, feature, '#1e5631'));
    }
    document.getElementById('featureForm').style.display = 'none';
    exitMode();
    syncInputs();
    renderFeatureList();
  });

  syncInputs();
  renderFeatureList();

  function initMap(center) {
    const map = L.map('digitizeMap', { tap: true, tapTolerance: 15 }).setView(center, 19);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 20,
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    L.circleMarker(center, { radius: 6, color: '#154889', fillColor: '#154889', fillOpacity: 1 })
      .addTo(map)
      .bindTooltip('You are here');

    features.forEach((f) => savedLayers.push(drawFeature(map, f, '#1e5631')));

    map.on('click', (e) => {
      if (!mode) return;
      const ll = [e.latlng.lat, e.latlng.lng];
      if (mode === 'point') {
        pendingPoints = [ll];
        openFeatureForm();
      } else if (mode === 'rectangle') {
        if (pendingPoints.length === 0) {
          pendingPoints = [ll];
          redrawPending();
        } else {
          const c1 = pendingPoints[0];
          const c2 = ll;
          pendingPoints = [[c1[0], c1[1]], [c1[0], c2[1]], [c2[0], c2[1]], [c2[0], c1[1]]];
          redrawPending();
          openFeatureForm();
        }
      } else {
        pendingPoints.push(ll);
        redrawPending();
      }
    });

    leafletMap = map;
    setTimeout(() => map.invalidateSize(), 100);
  }

  function startMap(center, message) {
    if (mapStarted) return;
    mapStarted = true;
    const statusEl = document.getElementById('mapStatus');
    if (message) { statusEl.textContent = message; } else { statusEl.style.display = 'none'; }
    initMap(center);
  }

  // Some browsers silently never call either geolocation callback (e.g. on a
  // non-HTTPS/non-localhost origin, which blocks the Geolocation API outright).
  // A hard fallback timer guarantees the map — and therefore drawing — always
  // starts within a few seconds no matter what the device/browser does.
  function beginLocating() {
    if (locatingStarted) return;
    locatingStarted = true;
    const hardFallbackTimer = setTimeout(() => {
      startMap(FALLBACK_CENTER, 'Location took too long — showing default area. Zoom/pan to your location manually.');
    }, 5000);

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          clearTimeout(hardFallbackTimer);
          startMap([pos.coords.latitude, pos.coords.longitude]);
        },
        () => {
          clearTimeout(hardFallbackTimer);
          startMap(FALLBACK_CENTER, 'Could not get GPS location — showing default area. Zoom/pan to your location manually.');
        },
        { enableHighAccuracy: true, timeout: 4500 }
      );
    } else {
      clearTimeout(hardFallbackTimer);
      startMap(FALLBACK_CENTER, 'GPS not available on this device — showing default area.');
    }
  }

  // Leaflet must not be initialized while its container is hidden (display:none
  // gives it zero size and permanently corrupts its click/pixel math). If this
  // tab isn't the one showing yet, wait for it to actually become visible.
  const mapEl = document.getElementById('digitizeMap');
  const panel = mapEl.closest('.tab-panel');
  function panelVisible() { return panel && panel.offsetParent !== null; }

  if (panelVisible()) {
    beginLocating();
  }
  document.querySelectorAll('.tab-btn[data-tab="digitization"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!locatingStarted) { setTimeout(beginLocating, 50); }
      else if (leafletMap) { setTimeout(() => leafletMap.invalidateSize(), 50); }
    });
  });
})();
</script>
