<div class="driver-card">
  <h3>Parked Vehicles</h3>
  <p style="color:#8a8f90; font-size:13px;">Record cars parked between the Halteverbot signs.</p>

  <% if (parkedVehicles.length === 0) { %>
    <p style="color:#8a8f90;">No parked vehicles recorded yet.</p>
  <% } else { %>
    <div class="data-table-wrap">
      <table class="data-table">
        <thead><tr><th>Plate</th><th>Color</th><th>Brand / Model</th><th>Direction</th><th>Photo</th><th>Status</th></tr></thead>
        <tbody>
          <% parkedVehicles.forEach(v => { %>
            <tr>
              <td><a href="/driver/tasks/<%= task.order_id %>/parked-vehicles/<%= v.id %>/edit"><%= v.plate_number || '(no plate)' %></a></td>
              <td><%= v.vehicle_color || '—' %></td>
              <td><%= [v.vehicle_brand, v.vehicle_model].filter(Boolean).join(' ') || '—' %></td>
              <td><%= v.tyre_direction_hour || '—' %></td>
              <td><%= parkedVehiclePhotos[v.id] ? 'Uploaded' : '—' %></td>
              <td><span class="badge badge-<%= v.status === 'Submitted' ? 'confirmed' : 'pending' %>"><%= v.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <form method="POST" action="/driver/tasks/<%= task.order_id %>/parked-vehicles" style="margin-top:14px;">
    <button class="driver-btn-lg outline" type="submit">+ Add Parked Vehicle</button>
  </form>

  <form method="POST" action="/driver/tasks/<%= task.order_id %>/parked-vehicles/submit" style="margin-top:8px;">
    <button class="driver-btn-lg" type="submit" onclick="return confirm('Submit the parked vehicle list?');">Submit Vehicle List</button>
  </form>
</div>
