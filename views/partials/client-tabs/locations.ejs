<div class="admin-card">
  <h3>Locations</h3>
  <div class="data-table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>Location</th><th>Street</th><th>City</th><th>Type</th><th>Previous Aufträge</th><th>Map Status</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% if (locations.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No locations saved yet.</td></tr>
        <% } %>
        <% locations.forEach(l => { %>
          <tr>
            <td>LOC-<%= 2000 + l.id %></td>
            <td><%= l.street %><%= l.house_number ? ' ' + l.house_number : '' %></td>
            <td><%= l.city || '—' %></td>
            <td><%= l.location_type || '—' %></td>
            <td>—</td>
            <td><span class="badge badge-<%= l.map_status %>"><%= l.map_status %></span></td>
            <td style="display:flex; gap:6px; flex-wrap:wrap;">
              <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('edit-loc-<%= l.id %>').style.display = document.getElementById('edit-loc-<%= l.id %>').style.display === 'none' ? '' : 'none';">Edit</button>
              <form method="POST" action="/admin/clients/<%= client.id %>/locations/<%= l.id %>/delete" style="margin:0;" onsubmit="return confirm('Remove this location?');">
                <button type="submit" class="btn btn-outline btn-sm">Remove</button>
              </form>
            </td>
          </tr>
          <tr id="edit-loc-<%= l.id %>" style="display:none;">
            <td colspan="7">
              <form method="POST" action="/admin/clients/<%= client.id %>/locations/<%= l.id %>" class="form-grid">
                <div class="form-group"><label>Location Name</label><input type="text" name="location_name" value="<%= l.location_name || '' %>"></div>
                <div class="form-group"><label>Street</label><input type="text" name="street" value="<%= l.street %>" required></div>
                <div class="form-group"><label>House Number</label><input type="text" name="house_number" value="<%= l.house_number || '' %>"></div>
                <div class="form-group"><label>ZIP</label><input type="text" name="zip" value="<%= l.zip || '' %>"></div>
                <div class="form-group"><label>City</label><input type="text" name="city" value="<%= l.city || '' %>"></div>
                <div class="form-group">
                  <label>Location Type</label>
                  <select name="location_type">
                    <option value="">— select —</option>
                    <% LOCATION_TYPES.forEach(t => { %><option value="<%= t %>" <%= l.location_type === t ? 'selected' : '' %>><%= t %></option><% }) %>
                  </select>
                </div>
                <div class="form-group"><label>Side of Street</label><input type="text" name="side_of_street" value="<%= l.side_of_street || '' %>"></div>
                <div class="form-group"><label><input type="checkbox" name="opposite_side_required" value="1" <%= l.opposite_side_required ? 'checked' : '' %>> Opposite Side Required</label></div>
                <div class="form-group"><label>Length (meters)</label><input type="number" step="0.1" name="length_meters" value="<%= l.length_meters || '' %>"></div>
                <div class="form-group"><label>Parking Spaces</label><input type="number" name="parking_spaces" value="<%= l.parking_spaces || '' %>"></div>
                <div class="form-group"><label>GPS / Map Pin</label><input type="text" name="map_pin" value="<%= l.map_pin || '' %>"></div>
                <div class="form-group">
                  <label>Map Status</label>
                  <select name="map_status">
                    <option value="needed" <%= l.map_status === 'needed' ? 'selected' : '' %>>Map needed</option>
                    <option value="available" <%= l.map_status === 'available' ? 'selected' : '' %>>Map available</option>
                  </select>
                </div>
                <div class="form-group full"><label>Access Notes</label><textarea name="access_notes" rows="2"><%= l.access_notes || '' %></textarea></div>
                <div class="form-group"><button class="btn btn-sm" type="submit">Save</button></div>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="admin-card">
  <h3>+ Add Location</h3>
  <form method="POST" action="/admin/clients/<%= client.id %>/locations" class="form-grid">
    <div class="form-group"><label>Location Name</label><input type="text" name="location_name"></div>
    <div class="form-group"><label>Street</label><input type="text" name="street" required></div>
    <div class="form-group"><label>House Number</label><input type="text" name="house_number"></div>
    <div class="form-group"><label>ZIP</label><input type="text" name="zip"></div>
    <div class="form-group"><label>City</label><input type="text" name="city"></div>
    <div class="form-group">
      <label>Location Type</label>
      <select name="location_type">
        <option value="">— select —</option>
        <% LOCATION_TYPES.forEach(t => { %><option value="<%= t %>"><%= t %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><label>Side of Street</label><input type="text" name="side_of_street"></div>
    <div class="form-group"><label><input type="checkbox" name="opposite_side_required" value="1"> Opposite Side Required</label></div>
    <div class="form-group"><label>Length (meters)</label><input type="number" step="0.1" name="length_meters"></div>
    <div class="form-group"><label>Parking Spaces</label><input type="number" name="parking_spaces"></div>
    <div class="form-group"><label>GPS / Map Pin</label><input type="text" name="map_pin"></div>
    <div class="form-group">
      <label>Map Status</label>
      <select name="map_status">
        <option value="needed">Map needed</option>
        <option value="available">Map available</option>
      </select>
    </div>
    <div class="form-group full"><label>Access Notes</label><textarea name="access_notes" rows="2"></textarea></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">+ Add Location</button></div>
  </form>
</div>
