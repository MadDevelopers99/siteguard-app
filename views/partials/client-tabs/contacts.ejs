<div class="admin-card">
  <h3>Contacts</h3>
  <div class="data-table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>Name</th><th>Role</th><th>Phone</th><th>Mobile</th><th>Email</th><th>Preferred</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% if (contacts.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No contacts yet.</td></tr>
        <% } %>
        <% contacts.forEach(c => { %>
          <tr>
            <td><%= c.name %></td>
            <td><%= c.role %></td>
            <td><%= c.phone || '—' %></td>
            <td><%= c.mobile || '—' %></td>
            <td><%= c.email || '—' %></td>
            <td><%= c.is_preferred ? 'Yes' : 'No' %></td>
            <td style="display:flex; gap:6px; flex-wrap:wrap;">
              <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('edit-contact-<%= c.id %>').style.display = document.getElementById('edit-contact-<%= c.id %>').style.display === 'none' ? '' : 'none';">Edit</button>
              <% if (c.role === 'Main Contact' || c.role === 'Billing Contact') { %>
                <form method="POST" action="/admin/clients/<%= client.id %>/contacts/<%= c.id %>/prefer" style="margin:0;">
                  <button type="submit" class="btn btn-outline btn-sm">Set as <%= c.role %></button>
                </form>
              <% } %>
              <form method="POST" action="/admin/clients/<%= client.id %>/contacts/<%= c.id %>/delete" style="margin:0;" onsubmit="return confirm('Remove this contact?');">
                <button type="submit" class="btn btn-outline btn-sm">Remove</button>
              </form>
            </td>
          </tr>
          <tr id="edit-contact-<%= c.id %>" style="display:none;">
            <td colspan="7">
              <form method="POST" action="/admin/clients/<%= client.id %>/contacts/<%= c.id %>" class="form-grid">
                <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= c.name %>" required></div>
                <div class="form-group">
                  <label>Role</label>
                  <select name="role">
                    <% CONTACT_ROLES.forEach(r => { %><option value="<%= r %>" <%= c.role === r ? 'selected' : '' %>><%= r %></option><% }) %>
                  </select>
                </div>
                <div class="form-group"><label>Phone</label><input type="text" name="phone" value="<%= c.phone || '' %>"></div>
                <div class="form-group"><label>Mobile</label><input type="text" name="mobile" value="<%= c.mobile || '' %>"></div>
                <div class="form-group"><label>Email</label><input type="email" name="email" value="<%= c.email || '' %>"></div>
                <div class="form-group"><button class="btn btn-sm" type="submit">Save</button></div>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="admin-card">
  <h3>Add Contact</h3>
  <form method="POST" action="/admin/clients/<%= client.id %>/contacts" class="form-grid">
    <div class="form-group"><label>Name</label><input type="text" name="name" required></div>
    <div class="form-group">
      <label>Role</label>
      <select name="role">
        <% CONTACT_ROLES.forEach(r => { %><option value="<%= r %>"><%= r %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><label>Phone</label><input type="text" name="phone"></div>
    <div class="form-group"><label>Mobile</label><input type="text" name="mobile"></div>
    <div class="form-group"><label>Email</label><input type="email" name="email"></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">+ Add Contact</button></div>
  </form>
</div>
