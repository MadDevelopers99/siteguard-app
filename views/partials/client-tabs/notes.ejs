<div class="admin-card">
  <h3>Notes</h3>
  <form method="POST" action="/admin/clients/<%= client.id %>/notes">
    <div class="form-group full">
      <textarea name="notes" rows="8" style="width:100%;"><%= client.notes || '' %></textarea>
    </div>
    <button class="btn btn-sm" type="submit" style="margin-top:12px;">Save Notes</button>
  </form>
</div>
