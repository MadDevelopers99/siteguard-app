<div class="admin-card">
  <h3>Planned Inventory</h3>
  <form method="POST" action="/admin/requests/<%= request.id %>/inventory/suggest" style="margin-bottom:16px;">
    <button class="btn btn-outline btn-sm" type="submit">Suggest Inventory</button>
  </form>

  <div class="data-table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>Item</th><th>Category</th><th>Planned Qty</th><th>Unit</th><th>Status</th><th>Source</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% if (inventoryRows.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No inventory planned yet.</td></tr>
        <% } %>
        <% inventoryRows.forEach(r => { %>
          <tr>
            <td><%= r.item_name %></td>
            <td><%= r.category || '—' %></td>
            <td><%= r.planned_qty %></td>
            <td><%= r.unit %></td>
            <td><%= r.status %></td>
            <td><%= r.source %></td>
            <td>
              <form method="POST" action="/admin/requests/<%= request.id %>/inventory/<%= r.id %>/delete" style="margin:0;">
                <button type="submit" class="btn btn-outline btn-sm">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="admin-card">
  <h3>+ Add Inventory Line</h3>
  <form method="POST" action="/admin/requests/<%= request.id %>/inventory" class="form-grid">
    <div class="form-group"><label>Item Name</label><input type="text" name="item_name" required></div>
    <div class="form-group"><label>Category</label><input type="text" name="category"></div>
    <div class="form-group"><label>Planned Qty</label><input type="number" step="0.1" name="planned_qty" required></div>
    <div class="form-group"><label>Unit</label><input type="text" name="unit" value="pcs"></div>
    <div class="form-group">
      <label>Status</label>
      <select name="status">
        <option value="Available">Available</option>
        <option value="Check">Check</option>
      </select>
    </div>
    <div class="form-group"><label>Notes</label><input type="text" name="notes"></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Add</button></div>
  </form>
</div>
