<div class="admin-card">
  <h3>Calculate Pricing</h3>
  <form method="POST" action="/admin/requests/<%= request.id %>/pricing/calculate" class="form-grid">
    <div class="form-group">
      <label>Map Fee</label>
      <select name="map_fee_tier">
        <% MAP_FEE_TIERS.forEach(t => { %><option value="<%= t.value %>" <%= request.map_fee_tier === t.value ? 'selected' : '' %>><%= t.label %></option><% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Transport Zone</label>
      <select name="transport_zone">
        <% TRANSPORT_ZONES.forEach(t => { %><option value="<%= t.value %>" <%= request.transport_zone === t.value ? 'selected' : '' %>><%= t.label %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Calculate Pricing</button></div>
  </form>
</div>

<div class="admin-card">
  <h3>Pricing Table</h3>
  <div class="data-table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>Price Item</th><th>Calculation Type</th><th>Qty</th><th>Unit Price</th><th>Days</th><th>Net Total</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% if (pricingRows.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No pricing calculated yet.</td></tr>
        <% } %>
        <% pricingRows.forEach(p => { %>
          <tr>
            <td><%= p.price_item %></td>
            <td><%= p.calculation_type %></td>
            <td><%= p.qty %></td>
            <td>€<%= p.unit_price.toFixed(2) %></td>
            <td><%= p.days || '—' %></td>
            <td>€<%= p.net_total.toFixed(2) %></td>
            <td>
              <form method="POST" action="/admin/requests/<%= request.id %>/pricing/<%= p.id %>/delete" style="margin:0;">
                <button type="submit" class="btn btn-outline btn-sm">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div style="text-align:right; margin-top:14px; font-family: var(--font-mono);">
    <div>Subtotal Net: €<%= (request.subtotal_net || 0).toFixed(2) %></div>
    <div>VAT <%= request.vat_rate || 19 %>%: €<%= (request.vat_amount || 0).toFixed(2) %></div>
    <div style="font-size:20px; font-weight:600;">Total Gross: €<%= (request.total_gross || 0).toFixed(2) %></div>
  </div>
</div>

<div class="admin-card">
  <h3>+ Add Manual Line (e.g. discount)</h3>
  <form method="POST" action="/admin/requests/<%= request.id %>/pricing" class="form-grid">
    <div class="form-group"><label>Price Item</label><input type="text" name="price_item" required placeholder="e.g. Discount"></div>
    <div class="form-group"><label>Calculation Type</label><input type="text" name="calculation_type" value="Manual"></div>
    <div class="form-group"><label>Qty</label><input type="number" step="0.1" name="qty" value="1"></div>
    <div class="form-group"><label>Unit Price</label><input type="number" step="0.01" name="unit_price" value="0"></div>
    <div class="form-group"><label>Days</label><input type="number" step="0.1" name="days"></div>
    <div class="form-group"><label>Net Total (use negative for discount)</label><input type="number" step="0.01" name="net_total" required></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Add Line</button></div>
  </form>
</div>
