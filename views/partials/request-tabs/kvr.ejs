<div class="admin-card">
  <h3>Permission / KVR</h3>
  <form method="POST" action="/admin/requests/<%= request.id %>/kvr" class="form-grid">
    <div class="form-group"><label><input type="checkbox" name="kvr_required" value="1" <%= request.kvr_required ? 'checked' : '' %>> KVR Required</label></div>
    <div class="form-group">
      <label>KVR Status</label>
      <select name="kvr_status">
        <% KVR_STATUS_OPTIONS.forEach(s => { %><option value="<%= s %>" <%= request.kvr_status === s ? 'selected' : '' %>><%= s %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><label>Authority / City</label><input type="text" name="kvr_authority" value="<%= request.kvr_authority || '' %>"></div>
    <div class="form-group"><label>Permission Number</label><input type="text" name="kvr_permission_number" value="<%= request.kvr_permission_number || '' %>"></div>
    <div class="form-group"><label>Valid From</label><input type="date" name="kvr_valid_from" value="<%= request.kvr_valid_from || '' %>"></div>
    <div class="form-group"><label>Valid To</label><input type="date" name="kvr_valid_to" value="<%= request.kvr_valid_to || '' %>"></div>
    <div class="form-group full"><label>Special Conditions</label><textarea name="kvr_special_conditions" rows="3"><%= request.kvr_special_conditions || '' %></textarea></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">Save</button></div>
  </form>
  <p style="color:#8a8f90; margin-top:14px;">Upload the KVR permit itself on the Documents tab (category "KVR Permission").</p>
</div>
