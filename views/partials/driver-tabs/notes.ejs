<div class="admin-card">
  <h3>Notes</h3>
  <% if (notes.length === 0) { %>
    <p style="color:#8a8f90;">No notes yet.</p>
  <% } %>
  <% notes.forEach(n => { %>
    <div style="padding:10px 0; border-bottom:1px solid var(--concrete-2);">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <span class="badge badge-confirmed"><%= n.note_type %></span>
        <span style="font-size:12px; color:#8a8f90;"><%= n.created_at %> — <%= n.created_by %><%= n.is_pinned ? ' 📌' : '' %></span>
      </div>
      <p style="margin:6px 0;"><%= n.note_text %><%= n.is_private ? ' (private)' : '' %></p>
      <div style="display:flex; gap:6px;">
        <form method="POST" action="/main-admin/team/drivers/<%= driver.id %>/notes/<%= n.id %>/pin" style="margin:0;">
          <button type="submit" class="btn btn-outline btn-sm"><%= n.is_pinned ? 'Unpin' : 'Pin' %></button>
        </form>
        <form method="POST" action="/main-admin/team/drivers/<%= driver.id %>/notes/<%= n.id %>/delete" style="margin:0;">
          <button type="submit" class="btn btn-outline btn-sm">Delete</button>
        </form>
      </div>
    </div>
  <% }) %>
</div>

<div class="admin-card">
  <h3>+ Add Note</h3>
  <form method="POST" action="/main-admin/team/drivers/<%= driver.id %>/notes" class="form-grid">
    <div class="form-group">
      <label>Note Type</label>
      <select name="note_type">
        <% DRIVER_NOTE_TYPES.forEach(t => { %><option value="<%= t %>"><%= t %></option><% }) %>
      </select>
    </div>
    <div class="form-group"><label><input type="checkbox" name="is_private" value="1"> Private</label></div>
    <div class="form-group full"><label>Note</label><textarea name="note_text" rows="2" required></textarea></div>
    <div class="form-group"><button class="btn btn-sm" type="submit">+ Add Note</button></div>
  </form>
</div>
