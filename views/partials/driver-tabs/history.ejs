<div class="admin-card">
  <h3>History</h3>
  <% if (history.length === 0) { %>
    <p style="color:#8a8f90;">No activity yet.</p>
  <% } else { %>
    <ul style="margin:0; padding-left:20px;">
      <% history.forEach(h => { %>
        <li><span style="font-family: var(--font-mono); color:#8a8f90;"><%= h.created_at %></span> — <%= h.action_text %> <span style="color:#8a8f90;">(<%= h.changed_by %>)</span></li>
      <% }) %>
    </ul>
  <% } %>
</div>
