<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>New Order (Email) — SiteGuard Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/admin-sidebar', { active: 'new-order' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Add Order Received by Email</h1>
      <a href="/admin/dashboard" style="text-decoration:none; font-size:14px;">&larr; Back to orders</a>
    </div>

    <form method="POST" action="/admin/orders/new">
      <div class="admin-card">
        <h3>Client</h3>
        <div style="margin-bottom:14px;">
          <label style="margin-right:16px;"><input type="radio" name="client_mode" value="existing" checked onchange="toggleClientMode()"> Existing client</label>
          <label><input type="radio" name="client_mode" value="new" onchange="toggleClientMode()"> Register new client</label>
        </div>

        <div id="existingClientBlock" class="form-grid full">
          <div class="form-group">
            <label>Select client</label>
            <select name="client_id">
              <option value="">— choose —</option>
              <% clients.forEach(c => { %>
                <option value="<%= c.id %>" <%= String(preselectClientId) === String(c.id) ? 'selected' : '' %>><%= c.name %><%= c.company ? ' — ' + c.company : '' %> (<%= c.email || 'no email' %>)</option>
              <% }) %>
            </select>
          </div>
        </div>

        <div id="newClientBlock" class="form-grid" style="display:none;">
          <div class="form-group"><label>Name *</label><input type="text" name="name"></div>
          <div class="form-group"><label>Company</label><input type="text" name="company"></div>
          <div class="form-group"><label>Email</label><input type="email" name="email"></div>
          <div class="form-group"><label>Phone</label><input type="text" name="phone"></div>
          <div class="form-group"><label>Address</label><input type="text" name="address"></div>
          <div class="form-group"><label>City</label><input type="text" name="city"></div>
        </div>
      </div>

      <div class="admin-card">
        <h3>Order Info</h3>
        <div class="form-grid">
          <div class="form-group"><label>Site / delivery address</label><input type="text" name="site_address"></div>
          <div class="form-group"><label>Needed by</label><input type="date" name="needed_by"></div>
        </div>
        <div class="form-group full" style="margin-top:10px;">
          <label>Notes (paste relevant email text here if useful)</label>
          <textarea name="notes" rows="3"></textarea>
        </div>
      </div>

      <div class="admin-card">
        <h3>Items</h3>
        <div id="lineItemsContainer"></div>
        <button type="button" class="btn btn-outline btn-sm" id="addLineBtn">+ Add item</button>
      </div>

      <button class="btn" type="submit" style="font-size:16px; padding:12px 24px;">Save Order</button>
    </form>
  </div>
</div>

<script>
  const ITEMS = <%- JSON.stringify(items.map(i => ({ id: i.id, name: i.name, sku: i.sku, price: i.price }))) %>;

  function toggleClientMode() {
    const mode = document.querySelector('input[name="client_mode"]:checked').value;
    document.getElementById('existingClientBlock').style.display = mode === 'existing' ? '' : 'none';
    document.getElementById('newClientBlock').style.display = mode === 'new' ? '' : 'none';
  }

  function addLineRow() {
    const container = document.getElementById('lineItemsContainer');
    const row = document.createElement('div');
    row.className = 'order-line-item-row';
    const options = ITEMS.map(i => `<option value="${i.id}">${i.sku} — ${i.name} (€${i.price.toFixed(2)})</option>`).join('');
    row.innerHTML = `
      <select name="item_ids">
        <option value="">— select item —</option>
        ${options}
      </select>
      <input type="number" name="quantities" value="1" min="1">
      <button type="button" class="remove-line">Remove</button>
    `;
    row.querySelector('.remove-line').addEventListener('click', () => row.remove());
    container.appendChild(row);
  }

  document.getElementById('addLineBtn').addEventListener('click', addLineRow);
  addLineRow(); // start with one row
</script>
</body>
</html>
