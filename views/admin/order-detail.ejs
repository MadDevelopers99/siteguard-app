<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Order <%= order.order_number %> — SiteGuard Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/admin-sidebar', { active: 'dashboard' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Order <%= order.order_number %></h1>
      <a href="/admin/dashboard" style="text-decoration:none; font-size:14px;">&larr; Back to orders</a>
    </div>

    <div class="admin-card">
      <h3>Client Info</h3>
      <div class="form-grid">
        <div><strong>Name:</strong> <%= order.name %></div>
        <div><strong>Company:</strong> <%= order.company || '—' %></div>
        <div><strong>Email:</strong> <%= order.email || '—' %></div>
        <div><strong>Phone:</strong> <%= order.phone || '—' %></div>
        <div><strong>City:</strong> <%= order.city || '—' %></div>
        <div><strong>Address:</strong> <%= order.address || '—' %></div>
      </div>
    </div>

    <div class="admin-card">
      <h3>Order Details</h3>
      <div class="form-grid">
        <div><strong>Source:</strong> <span class="badge badge-<%= order.source %>"><%= order.source %></span></div>
        <div><strong>Status:</strong> <span class="badge badge-<%= order.status %>"><%= order.status %></span></div>
        <div><strong>Site address:</strong> <%= order.site_address || '—' %></div>
        <div><strong>Needed by:</strong> <%= order.needed_by || '—' %></div>
        <div><strong>Created:</strong> <%= order.created_at %></div>
        <div><strong>Notes:</strong> <%= order.notes || '—' %></div>
      </div>

      <form method="POST" action="/admin/orders/<%= order.order_id %>/status" style="margin-top:16px; display:flex; gap:10px; align-items:center;">
        <label style="margin:0; font-size:13px; font-weight:600;">Update status:</label>
        <select name="status">
          <% ["pending","confirmed","dispatched","delivered","cancelled"].forEach(s => { %>
            <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
          <% }) %>
        </select>
        <button class="btn btn-sm" type="submit">Save</button>
      </form>
    </div>

    <% if (linkedRequest) { %>
      <div class="admin-card">
        <h3>From Request <a class="order-link" href="/admin/requests/<%= linkedRequest.id %>"><%= linkedRequest.request_number %></a></h3>
        <div class="form-grid">
          <div><strong>Request Type:</strong> <%= linkedRequest.request_type || '—' %></div>
          <div><strong>KVR:</strong> <%= linkedRequest.kvr_required ? linkedRequest.kvr_status : 'Not Required' %></div>
          <div><strong>Absicherung:</strong> <%= linkedRequest.absicherung_required ? linkedRequest.absicherung_type : 'Not Required' %></div>
        </div>
      </div>

      <div class="admin-card">
        <h3>Pricing Breakdown</h3>
        <div class="data-table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Price Item</th><th>Calculation Type</th><th>Qty</th><th>Unit Price</th><th>Days</th><th>Net Total</th></tr>
            </thead>
            <tbody>
              <% requestPricing.forEach(p => { %>
                <tr>
                  <td><%= p.price_item %></td>
                  <td><%= p.calculation_type %></td>
                  <td><%= p.qty %></td>
                  <td>€<%= p.unit_price.toFixed(2) %></td>
                  <td><%= p.days || '—' %></td>
                  <td>€<%= p.net_total.toFixed(2) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div style="text-align:right; margin-top:14px; font-family: var(--font-mono);">
          <div>Subtotal Net: €<%= (linkedRequest.subtotal_net || 0).toFixed(2) %></div>
          <div>VAT <%= linkedRequest.vat_rate || 19 %>%: €<%= (linkedRequest.vat_amount || 0).toFixed(2) %></div>
          <div style="font-size:20px; font-weight:600;">Total Gross: €<%= order.total.toFixed(2) %></div>
        </div>
      </div>
    <% } else { %>
      <div class="admin-card">
        <h3>Items</h3>
        <div class="data-table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>Item</th><th>Unit Price</th><th>Qty</th><th>Line Total</th></tr>
            </thead>
            <tbody>
              <% lineItems.forEach(li => { %>
                <tr>
                  <td><%= li.item_name %></td>
                  <td>€<%= li.unit_price.toFixed(2) %></td>
                  <td><%= li.quantity %></td>
                  <td>€<%= li.line_total.toFixed(2) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div style="text-align:right; margin-top:14px; font-family: var(--font-mono); font-size:20px; font-weight:600;">
          Total: €<%= order.total.toFixed(2) %>
        </div>
      </div>
    <% } %>
  </div>
</div>
</body>
</html>
