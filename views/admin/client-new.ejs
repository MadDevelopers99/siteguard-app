<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>New Client — SiteGuard Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/admin-sidebar', { active: 'clients' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>New Client</h1>
      <a href="/admin/clients" style="text-decoration:none; font-size:14px;">&larr; Back to clients</a>
    </div>

    <form method="POST" action="/admin/clients">
      <div class="admin-card">
        <h3>Company</h3>
        <div class="form-grid">
          <div class="form-group"><label>Company Name</label><input type="text" name="company"></div>
          <div class="form-group">
            <label>Client Type</label>
            <select name="client_type">
              <option value="">— select —</option>
              <% CLIENT_TYPES.forEach(t => { %><option value="<%= t %>"><%= t %></option><% }) %>
            </select>
          </div>
        </div>
      </div>

      <div class="admin-card">
        <h3>Main Contact</h3>
        <div class="form-grid">
          <div class="form-group"><label>Contact Person *</label><input type="text" name="name" required></div>
          <div class="form-group"><label>Phone</label><input type="text" name="contact_phone"></div>
          <div class="form-group"><label>Mobile</label><input type="text" name="contact_mobile"></div>
          <div class="form-group"><label>Email</label><input type="email" name="contact_email"></div>
        </div>
      </div>

      <div class="admin-card">
        <h3>Company Address</h3>
        <div class="form-grid">
          <div class="form-group"><label>Street</label><input type="text" name="street"></div>
          <div class="form-group"><label>House Number</label><input type="text" name="house_number"></div>
          <div class="form-group"><label>ZIP</label><input type="text" name="zip"></div>
          <div class="form-group"><label>City</label><input type="text" name="city"></div>
          <div class="form-group"><label>Country</label><input type="text" name="country" value="Germany"></div>
        </div>
      </div>

      <div class="admin-card">
        <h3>General</h3>
        <div class="form-grid">
          <div class="form-group"><label>General Email</label><input type="email" name="email"></div>
          <div class="form-group"><label>General Phone</label><input type="text" name="phone"></div>
        </div>
        <div class="form-group full" style="margin-top:10px;">
          <label>Client Notes</label>
          <textarea name="notes" rows="3"></textarea>
        </div>
      </div>

      <button class="btn" type="submit" style="font-size:16px; padding:12px 24px;">Create Client</button>
    </form>
  </div>
</div>
</body>
</html>
