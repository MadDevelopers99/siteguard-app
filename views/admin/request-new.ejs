<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>New Client Request — SiteGuard Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/admin-sidebar', { active: 'clients' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>New Client Request</h1>
      <% if (clientRow) { %>
        <a href="/admin/clients/<%= clientRow.id %>" style="text-decoration:none; font-size:14px;">&larr; Back to <%= clientRow.company || clientRow.name %></a>
      <% } else { %>
        <a href="/admin/clients" style="text-decoration:none; font-size:14px;">&larr; Back to clients</a>
      <% } %>
    </div>

    <form method="POST" action="/admin/requests">
      <div class="admin-card">
        <h3>Client</h3>
        <% if (clientRow) { %>
          <input type="hidden" name="client_id" value="<%= clientRow.id %>">
          <p><%= clientRow.company || clientRow.name %> — <%= clientRow.name %></p>
        <% } else { %>
          <div class="form-group">
            <label>Client</label>
            <select name="client_id" required>
              <option value="">— choose —</option>
              <% clients.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.company || c.name %> (<%= c.name %>)</option>
              <% }) %>
            </select>
          </div>
        <% } %>
      </div>

      <div class="admin-card">
        <h3>Request Details</h3>
        <div class="form-grid">
          <div class="form-group">
            <label>Request Type</label>
            <select name="request_type">
              <option value="">— select —</option>
              <% REQUEST_TYPES.forEach(t => { %><option value="<%= t %>"><%= t %></option><% }) %>
            </select>
          </div>
          <div class="form-group"><label>Purpose</label><input type="text" name="purpose"></div>
          <div class="form-group"><label>Date From</label><input type="date" name="date_from"></div>
          <div class="form-group"><label>Date To</label><input type="date" name="date_to"></div>
          <div class="form-group"><label>Time From</label><input type="time" name="time_from"></div>
          <div class="form-group"><label>Time To</label><input type="time" name="time_to"></div>
          <div class="form-group"><label>Number of Days</label><input type="number" name="number_of_days" min="1"></div>
          <div class="form-group">
            <label>Urgency</label>
            <select name="urgency">
              <% URGENCY_OPTIONS.forEach(u => { %><option value="<%= u %>"><%= u %></option><% }) %>
            </select>
          </div>
          <div class="form-group"><label>Required Length (meters)</label><input type="number" step="0.1" name="required_length_meters"></div>
          <div class="form-group"><label>Parking Spaces</label><input type="number" name="parking_spaces"></div>
          <div class="form-group">
            <label>Side</label>
            <select name="side">
              <option value="one">One Side</option>
              <option value="both">Both Sides</option>
            </select>
          </div>
        </div>
        <div class="form-group full" style="margin-top:10px;">
          <label>Special Instructions</label>
          <textarea name="special_instructions" rows="3"></textarea>
        </div>
      </div>

      <button class="btn" type="submit" style="font-size:16px; padding:12px 24px;">Start Request</button>
    </form>
  </div>
</div>
</body>
</html>
