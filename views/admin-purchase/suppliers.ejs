<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Suppliers — SiteGuard Purchase</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'pur-suppliers' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Suppliers</h1>
      <a class="btn btn-sm" style="text-decoration:none;" href="/admin/purchase/suppliers/new">+ Add Supplier</a>
    </div>

    <div class="data-table-wrap">
      <table class="data-table">
        <thead><tr><th>Name</th><th>Contact</th><th>Phone</th><th>Email</th><th>Category</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (suppliers.length === 0) { %>
            <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No suppliers yet.</td></tr>
          <% } %>
          <% suppliers.forEach(s => { %>
            <tr>
              <td><%= s.name %></td>
              <td><%= s.contact_person || '—' %></td>
              <td><%= s.phone || '—' %></td>
              <td><%= s.email || '—' %></td>
              <td><%= s.category || '—' %></td>
              <td><span class="badge badge-<%= statusBadgeClass(s.status) %>"><%= s.status %></span></td>
              <td><a class="btn btn-outline btn-sm" style="text-decoration:none;" href="/admin/purchase/suppliers/<%= s.id %>/edit">Edit</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
