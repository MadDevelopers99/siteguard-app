<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create Goods Receipt — SiteGuard Purchase</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'pur-receipts' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Create Goods Receipt</h1>
      <a href="/admin/purchase/receipts" style="text-decoration:none; font-size:14px;">&larr; Back to goods received</a>
    </div>

    <% if (!selectedPo) { %>
      <div class="admin-card">
        <h3>Select a Purchase Order</h3>
        <form method="GET" action="/admin/purchase/receipts/new" class="form-grid">
          <div class="form-group">
            <label>Purchase Order</label>
            <select name="po_id" onchange="this.form.submit()">
              <option value="">— select —</option>
              <% orders.forEach(o => { %><option value="<%= o.id %>"><%= o.po_number %> — <%= o.supplier_name %></option><% }) %>
            </select>
          </div>
        </form>
        <% if (orders.length === 0) { %>
          <p style="color:#8a8f90; margin-top:14px;">No purchase orders are ready to receive (must be status "Ordered" or "Partially Received").</p>
        <% } %>
      </div>
    <% } else { %>
      <form method="POST" action="/admin/purchase/receipts">
        <input type="hidden" name="po_id" value="<%= selectedPo.id %>">
        <div class="admin-card">
          <h3><%= selectedPo.po_number %></h3>
          <div class="form-grid">
            <div class="form-group"><label>Received By</label><input type="text" name="received_by"></div>
            <div class="form-group"><label>Delivery Note Number</label><input type="text" name="delivery_note_number"></div>
            <div class="form-group"><label>Storage Location</label><input type="text" name="storage_location"></div>
          </div>
          <div class="form-group full" style="margin-top:10px;"><label>Notes</label><textarea name="notes" rows="2"></textarea></div>
        </div>

        <div class="admin-card">
          <h3>Goods Received Item Table</h3>
          <div class="data-table-wrap">
            <table class="data-table">
              <thead><tr><th>Item</th><th>Ordered Qty</th><th>Received Qty</th><th>Condition</th></tr></thead>
              <tbody>
                <% poItems.forEach(pi => { %>
                  <tr>
                    <td>
                      <input type="hidden" name="po_item_id" value="<%= pi.id %>">
                      <input type="hidden" name="item_name" value="<%= pi.item_name %>">
                      <%= pi.item_name %>
                    </td>
                    <td><input type="hidden" name="ordered_qty" value="<%= pi.qty %>"><%= pi.qty %></td>
                    <td><input type="number" step="0.1" name="received_qty" value="<%= pi.qty %>" style="width:100px;"></td>
                    <td>
                      <select name="condition">
                        <option value="Good">Good</option>
                        <option value="Damaged">Damaged</option>
                        <option value="Missing">Missing</option>
                      </select>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <button class="btn" type="submit" style="font-size:16px; padding:12px 24px;">Confirm Received Quantity</button>
      </form>
    <% } %>
  </div>
</div>
</body>
</html>
