<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Price Rules — SiteGuard Purchase</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'pur-pricerules' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Price Rules</h1>
    </div>
    <p style="color:var(--steel); margin:-14px 0 20px; font-size:14px;">
      Controls how purchase price becomes internal SG price. Applied manually when pricing a batch (Wholesale Stock / Batches).
    </p>

    <div class="data-table-wrap">
      <table class="data-table">
        <thead><tr><th>Rule Name</th><th>Category</th><th>Method</th><th>Markup %</th><th>Fixed Fee</th><th>Fixed Price</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (rules.length === 0) { %>
            <tr><td colspan="8" style="text-align:center; color:#8a8f90;">No price rules yet.</td></tr>
          <% } %>
          <% rules.forEach(r => { %>
            <tr>
              <td><%= r.rule_name %></td>
              <td><%= r.item_category || '—' %></td>
              <td><%= r.calculation_method %></td>
              <td><%= r.markup_pct || '—' %></td>
              <td><%= r.fixed_fee ? '€' + r.fixed_fee.toFixed(2) : '—' %></td>
              <td><%= r.fixed_price ? '€' + r.fixed_price.toFixed(2) : '—' %></td>
              <td><span class="badge badge-<%= r.status === 'Active' ? 'active' : 'inactive' %>"><%= r.status %></span></td>
              <td>
                <form method="POST" action="/admin/purchase/price-rules/<%= r.id %>/deactivate" style="margin:0;">
                  <button type="submit" class="btn btn-outline btn-sm"><%= r.status === 'Active' ? 'Deactivate' : 'Activate' %></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="admin-card">
      <h3>+ Add Price Rule</h3>
      <form method="POST" action="/admin/purchase/price-rules" class="form-grid">
        <div class="form-group"><label>Rule Name *</label><input type="text" name="rule_name" required></div>
        <div class="form-group"><label>Item Category</label><input type="text" name="item_category"></div>
        <div class="form-group">
          <label>Calculation Method</label>
          <select name="calculation_method">
            <% PRICE_RULE_METHODS.forEach(m => { %><option value="<%= m %>"><%= m %></option><% }) %>
          </select>
        </div>
        <div class="form-group"><label>Markup %</label><input type="number" step="0.1" name="markup_pct" placeholder="e.g. 25"></div>
        <div class="form-group"><label>Fixed Fee (€)</label><input type="number" step="0.01" name="fixed_fee"></div>
        <div class="form-group"><label>Fixed Price (€)</label><input type="number" step="0.01" name="fixed_price"></div>
        <div class="form-group"><label>Minimum Price (€)</label><input type="number" step="0.01" name="minimum_price"></div>
        <div class="form-group"><label>Valid From</label><input type="date" name="valid_from"></div>
        <div class="form-group"><label>Valid To</label><input type="date" name="valid_to"></div>
        <div class="form-group"><button class="btn btn-sm" type="submit">+ Add Price Rule</button></div>
      </form>
    </div>
  </div>
</div>
</body>
</html>
