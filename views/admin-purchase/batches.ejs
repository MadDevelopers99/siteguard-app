<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wholesale Stock / Batches — SiteGuard Purchase</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'pur-batches' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Wholesale Stock / Batches</h1>
    </div>
    <p style="color:var(--steel); margin:-14px 0 20px; font-size:14px;">
      Material purchased in bulk but not yet sold/transferred to SG.
    </p>

    <div class="data-table-wrap">
      <table class="data-table">
        <thead><tr><th>Batch #</th><th>Item</th><th>Supplier</th><th>Purchased</th><th>Available</th><th>Purchase Cost</th><th>SG Price</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (batches.length === 0) { %>
            <tr><td colspan="9" style="text-align:center; color:#8a8f90;">No wholesale batches yet.</td></tr>
          <% } %>
          <% batches.forEach(b => { %>
            <tr>
              <td><%= b.batch_number %></td>
              <td><%= b.item_name %></td>
              <td><%= b.supplier_name || '—' %></td>
              <td><%= b.purchased_qty %></td>
              <td><%= b.available_qty %></td>
              <td>€<%= b.purchase_unit_cost.toFixed(2) %></td>
              <td>€<%= b.internal_sg_sell_price.toFixed(2) %></td>
              <td><span class="badge badge-<%= statusBadgeClass(b.status) %>"><%= b.status %></span></td>
              <td>
                <form method="POST" action="/admin/purchase/batches/<%= b.id %>/price" style="display:flex; gap:6px;">
                  <input type="number" step="0.01" name="internal_sg_sell_price" value="<%= b.internal_sg_sell_price %>" style="width:80px;" placeholder="SG price">
                  <button class="btn btn-outline btn-sm" type="submit">Save</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
