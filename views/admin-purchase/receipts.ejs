<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Goods Received — SiteGuard Purchase</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/inventory-sidebar', { active: 'pur-receipts' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Goods Received</h1>
      <a class="btn btn-sm" style="text-decoration:none;" href="/admin/purchase/receipts/new">+ Create Goods Receipt</a>
    </div>

    <div class="data-table-wrap">
      <table class="data-table">
        <thead><tr><th>GR ID</th><th>PO ID</th><th>Supplier</th><th>Date Received</th><th>Received By</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (receipts.length === 0) { %>
            <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No goods receipts yet.</td></tr>
          <% } %>
          <% receipts.forEach(r => { %>
            <tr>
              <td><%= r.gr_number %></td>
              <td><%= r.po_number %></td>
              <td><%= r.supplier_name %></td>
              <td><%= r.received_date %></td>
              <td><%= r.received_by || '—' %></td>
              <td><span class="badge badge-<%= statusBadgeClass(r.status) %>"><%= r.status %></span></td>
              <td>
                <form method="POST" action="/admin/purchase/receipts/<%= r.id %>/create-batch" style="margin:0;">
                  <button type="submit" class="btn btn-outline btn-sm">Create Wholesale Batch</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
