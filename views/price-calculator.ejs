<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= company.name %> <%= company.tagline %> — No-Parking Zone Price Calculator</title>
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>

<header class="topbar">
  <a href="/" class="brand pc-brand">
    <span class="mark">SG</span>
    <span class="pc-brand-text"><strong>SITE GUARD</strong><small>TRAFFIC SERVICES</small></span>
  </a>
  <nav class="pc-nav">
    <a href="#">Services</a>
    <a href="#">No-Parking Zones</a>
    <a href="#">Traffic Safety</a>
    <a href="#">Construction Sites</a>
    <a href="#calculator">Prices</a>
    <a href="#contactSection">Contact</a>
  </nav>
  <div class="pc-header-right">
    <div class="pc-header-contact">
      <span><%= company.phone %></span>
      <small><%= company.hours %></small>
    </div>
    <a class="btn btn-outline" href="tel:<%= company.phone.replace(/[^+\d]/g, '') %>">Call Now</a>
    <a class="btn" href="#" onclick="return false;" title="Customer login coming soon">Login</a>
  </div>
</header>

<div class="hazard-rule"></div>

<section class="pc-hero">
  <div class="pc-hero-left">
    <img src="/images/signs/haltverbot.svg" alt="No-Parking Zone sign" class="pc-hero-sign">
    <span class="pc-badge">Reliable traffic service for private and commercial projects</span>
    <h1>Calculate your no-parking zone price in seconds.</h1>
    <p class="pc-sub">Enter your location, dates, time, and zone length. We calculate your estimated price instantly and guide you through the next step.</p>
    <p class="pc-support">Whether you are planning a move, delivery, construction work, container placement, crane operation, or event, we help you organize the right temporary traffic solution.</p>

    <div class="pc-trust-row">
      <div class="pc-trust-item"><span class="pc-trust-icon">&#9201;</span>Fast response</div>
      <div class="pc-trust-item"><span class="pc-trust-icon">&#128100;</span>Personal contact</div>
      <div class="pc-trust-item"><span class="pc-trust-icon">&#128203;</span>Structured planning</div>
      <div class="pc-trust-item"><span class="pc-trust-icon">&#128736;</span>On-site setup</div>
      <div class="pc-trust-item"><span class="pc-trust-icon">&#128196;</span>Clear documentation</div>
    </div>

    <div class="pc-hero-buttons">
      <a class="btn" href="#calculator">Calculate Price</a>
      <a class="btn btn-outline" href="#calculator">Check Availability</a>
      <a class="btn btn-outline" href="tel:<%= company.phone.replace(/[^+\d]/g, '') %>">Call Now</a>
    </div>
  </div>

  <div class="pc-hero-right" id="calculator">
    <div class="pc-card">
      <h2>Calculate your no-parking zone price instantly</h2>
      <p class="pc-form-subtitle">Enter the details below. Your estimated price will be calculated immediately.</p>

      <form id="calcForm">
        <div id="addressBlocks">
          <div class="pc-address-block" data-index="0">
            <div class="pc-address-block-header" style="display:none;">
              <strong class="pc-address-title">Address 1</strong>
              <button type="button" class="pc-remove-address">Remove</button>
            </div>

            <div class="pc-form-grid">
              <div class="form-group"><label>City *</label><input type="text" name="addresses[0][city]" placeholder="Munich" required></div>
              <div class="form-group">
                <label>Reason / Purpose *</label>
                <select name="addresses[0][reason]" required>
                  <option value="">Select reason</option>
                  <% REASON_OPTIONS.forEach(r => { %><option value="<%= r %>"><%= r %></option><% }) %>
                </select>
              </div>
            </div>

            <div class="pc-form-grid">
              <div class="form-group"><label>Start Date *</label><input type="date" name="addresses[0][start_date]" required></div>
              <div class="form-group"><label>End Date *</label><input type="date" name="addresses[0][end_date]" required></div>
            </div>
            <div class="pc-form-grid">
              <div class="form-group"><label>Start Time *</label><input type="time" name="addresses[0][start_time]" value="07:00" required></div>
              <div class="form-group"><label>End Time *</label><input type="time" name="addresses[0][end_time]" value="17:00" required></div>
            </div>
            <div class="pc-form-grid">
              <div class="form-group"><label>Postal Code *</label><input type="text" name="addresses[0][postal_code]" placeholder="81677" required></div>
            </div>

            <div class="pc-section-label">FROM</div>
            <div class="pc-form-grid">
              <div class="form-group"><label>Street *</label><input type="text" name="addresses[0][from_street]" placeholder="Example Street" required></div>
              <div class="form-group"><label>House Number *</label><input type="text" name="addresses[0][from_house_number]" placeholder="35" required></div>
            </div>

            <div class="pc-section-label">TILL</div>
            <div class="pc-form-grid">
              <div class="form-group"><label>Street</label><input type="text" name="addresses[0][till_street]" placeholder="Example Street"></div>
              <div class="form-group"><label>House Number</label><input type="text" name="addresses[0][till_house_number]" placeholder="51"></div>
            </div>

            <div class="pc-form-grid">
              <div class="form-group">
                <label>Zone Length *</label>
                <select name="addresses[0][zone_length]" class="pc-zone-length-select" required>
                  <option value="">Select length</option>
                  <% ZONE_LENGTH_OPTIONS.forEach(z => { %><option value="<%= z %>"><%= z %></option><% }) %>
                </select>
              </div>
              <div class="form-group">
                <label>&nbsp;</label>
                <label class="pc-checkbox-label"><input type="checkbox" name="addresses[0][both_sides]" value="1"> No-parking zone needed on both sides</label>
              </div>
            </div>

            <div class="pc-map-section">
              <label>Mark the zone on the map (optional)</label>
              <div class="pc-map-toolbar">
                <button type="button" class="pc-map-tool active" data-mode="point">Mark Point</button>
                <button type="button" class="pc-map-tool" data-mode="line">Draw Line</button>
                <button type="button" class="pc-map-tool" data-mode="polygon">Draw Area</button>
                <button type="button" class="pc-map-tool-action" id="pcFinishShapeBtn" style="display:none;">Finish Shape</button>
                <button type="button" class="pc-map-tool-action" id="pcUndoBtn">Undo</button>
                <button type="button" class="pc-map-tool-action" id="pcClearMapBtn">Clear</button>
                <button type="button" class="pc-map-tool-action" id="pcStopDrawBtn" style="display:none;">Stop Drawing (Pan Map)</button>
              </div>
              <div id="pcMarkMap" class="pc-mark-map"></div>
              <div class="pc-map-meta">
                <span id="pcMapLength">Drawn length: —</span>
                <button type="button" class="btn btn-outline btn-sm" id="pcSaveMarkingBtn">Save Marking</button>
              </div>
              <p class="pc-map-note">Drawing a line measures its length and fills in Zone Length as "Custom length" for manual review. PDF export of your marked zone will be available once your request is confirmed and paid.</p>
              <input type="hidden" name="addresses[0][map_marking]" class="pc-map-marking-input">
            </div>
          </div>
        </div>

        <button type="button" class="btn btn-outline btn-block" id="addAddressBtn">+ Add New Address</button>

        <div class="form-group full" style="margin-top:14px;">
          <button class="btn btn-block" type="submit">Calculate Price</button>
        </div>
      </form>

      <div id="calcError" class="error-msg" style="display:none;"></div>

      <div id="priceResultsWrap"></div>

      <div id="manualReviewCard" class="pc-result-card" style="display:none;">
        <h3>Manual Review Needed</h3>
        <p>One or more zone lengths need manual review by our team. Send us your details and we'll get back to you with a price.</p>
      </div>

      <div id="contactSection" class="pc-contact-section" style="display:none;">
        <h3>Continue with this price</h3>
        <p class="pc-form-subtitle">Enter your details and we will guide you through the next step.</p>

        <div class="pc-client-toggle">
          <button type="button" class="pc-toggle-btn active" data-mode="new">New Client</button>
          <button type="button" class="pc-toggle-btn" data-mode="existing">Existing Client</button>
        </div>
        <p class="pc-existing-note" id="pcExistingNote" style="display:none;">
          Haben Sie bereits ein Kundenkonto? <a href="#" onclick="return false;">Log in</a> to reuse your saved details.
        </p>

        <form id="contactForm" class="pc-form-grid pc-form-grid-3">
          <input type="hidden" name="client_mode" id="clientModeInput" value="new">
          <input type="hidden" name="client_type" id="clientTypeInput" value="Private">

          <div class="form-group"><label>Vorname (First Name) *</label><input type="text" name="vorname" required></div>
          <div class="form-group"><label>Nachname (Last Name) *</label><input type="text" name="nachname" required></div>
          <div class="form-group"><label>Phone *</label><input type="text" name="phone" required></div>
          <div class="form-group"><label>Email *</label><input type="email" name="email" required></div>

          <div class="form-group full">
            <label>Client Type</label>
            <div class="pc-client-type-toggle">
              <button type="button" class="pc-type-btn active" data-type="Private">Private Client</button>
              <button type="button" class="pc-type-btn" data-type="Company">Company Client</button>
            </div>
          </div>
          <div class="form-group full" id="companyFieldWrap" style="display:none;">
            <label>Company Name</label><input type="text" name="company">
          </div>

          <div class="form-group"><label>Land (Country)</label><input type="text" name="country" value="Germany"></div>
          <div class="form-group"><label>Street</label><input type="text" name="street"></div>
          <div class="form-group"><label>House Number</label><input type="text" name="house_number"></div>
          <div class="form-group"><label>Postleitzahl (ZIP)</label><input type="text" name="zip"></div>
          <div class="form-group"><label>Stadt (City)</label><input type="text" name="city"></div>

          <div class="form-group full"><label>Notes</label><textarea name="notes" rows="2" placeholder="Additional information (optional)"></textarea></div>

          <div class="form-group full pc-payment-section">
            <label>Payment Method</label>
            <div class="pc-payment-options">
              <label class="pc-payment-option"><input type="radio" name="payment_method" value="bank_transfer" checked> Bank Transfer</label>
              <label class="pc-payment-option"><input type="radio" name="payment_method" value="card"> Credit / Debit Card</label>
              <label class="pc-payment-option"><input type="radio" name="payment_method" value="google_pay"> Google Pay</label>
            </div>
            <p class="pc-payment-note">Payment processing will be enabled once checkout goes live — no payment is taken yet.</p>
          </div>

          <div class="form-group full">
            <button class="btn btn-block" type="submit" id="continueBtn">Continue with This Price</button>
          </div>
        </form>
        <p class="pc-privacy">Your data will only be used to process your request.</p>
        <div id="submitResult" style="margin-top:10px; font-size:14px;"></div>
      </div>
    </div>
  </div>
</section>

<section class="pc-benefits">
  <div class="pc-benefit">
    <h4>Fast Processing</h4>
    <p>We review your request and respond quickly with the next steps.</p>
  </div>
  <div class="pc-benefit">
    <h4>Planning From One Source</h4>
    <p>From request to setup, the process stays clear and organized.</p>
  </div>
  <div class="pc-benefit">
    <h4>Flexible Service</h4>
    <p>We check short-notice dates, special requirements, and multiple locations.</p>
  </div>
  <div class="pc-benefit">
    <h4>Documentation</h4>
    <p>Photos, records, and relevant documents can be provided when required.</p>
  </div>
</section>

<p class="pc-legal">Implementation depends on local requirements and the responsible authority. Official approvals cannot be guaranteed.</p>

<script>
  window.PC_REASON_OPTIONS = <%- JSON.stringify(REASON_OPTIONS) %>;
  window.PC_ZONE_LENGTH_OPTIONS = <%- JSON.stringify(ZONE_LENGTH_OPTIONS) %>;
</script>
<script src="/js/price-calculator.js"></script>
</body>
</html>
