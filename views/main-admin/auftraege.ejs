<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Incoming Aufträge — SiteGuard Main Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/main-admin-sidebar', { active: 'auftraege' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Incoming Aufträge</h1>
      <form class="logout-form" method="POST" action="/main-admin/logout">
        <button type="submit">Log out (<%= mainAdminName %>)</button>
      </form>
    </div>

    <form class="filter-bar" method="GET" action="/main-admin/auftraege">
      <input type="text" name="q" placeholder="Search client, company, order #…" value="<%= filters.q %>">
      <select name="status">
        <option value="">All statuses</option>
        <% MAIN_ADMIN_STATUSES.forEach(s => { %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
      <button class="btn btn-outline btn-sm" type="submit">Filter</button>
    </form>

    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Auftrag ID</th><th>Client</th><th>Location</th><th>Type</th><th>Date</th>
            <th>KVR</th><th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
            <tr><td colspan="7" style="text-align:center; color:#8a8f90;">No Aufträge match these filters.</td></tr>
          <% } %>
          <% orders.forEach(o => {
               const request = requestByOrder[o.id];
          %>
            <tr onclick="window.location='/main-admin/auftraege/<%= o.id %>'" style="cursor:pointer;">
              <td><%= o.order_number %></td>
              <td><%= o.client_company || o.client_name %></td>
              <td><%= o.location_street ? (o.location_street + ', ' + (o.location_city || '')) : '—' %></td>
              <td><%= request ? (request.request_type || '—') : '—' %></td>
              <td><%= request ? (request.date_from || '—') + ' – ' + (request.date_to || '—') : '—' %></td>
              <td><%= request && request.kvr_required ? request.kvr_status : 'N/A' %></td>
              <td><span class="badge badge-<%= statusBadgeClass(o.main_admin_status) %>"><%= o.main_admin_status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
