<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Main Admin Login — SiteGuard</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="login-shell">
  <div class="login-card">
    <div class="brand"><span class="mark">SG</span> SiteGuard Main Admin</div>
    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form method="POST" action="/main-admin/login">
      <div class="form-group" style="margin-bottom:14px;">
        <label>Email</label>
        <input type="email" name="email" required autofocus>
      </div>
      <div class="form-group" style="margin-bottom:20px;">
        <label>Password</label>
        <input type="password" name="password" required>
      </div>
      <button class="btn btn-block" type="submit">Log in</button>
    </form>
    <div class="login-switch">
      Not Main Admin? <a href="/admin/login">Office Admin login</a> · <a href="/driver/login">Driver login</a>
    </div>
  </div>
</div>
</body>
</html>
