<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Settings — SiteGuard Main Admin</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-shell">
  <%- include('../partials/main-admin-sidebar', { active: 'settings' }) %>

  <div class="admin-main">
    <div class="admin-topline">
      <h1>Settings — Drivers</h1>
      <form class="logout-form" method="POST" action="/main-admin/logout">
        <button type="submit">Log out (<%= mainAdminName %>)</button>
      </form>
    </div>

    <div class="admin-card">
      <h3>Driver Accounts</h3>
      <div class="data-table-wrap">
        <table class="data-table">
          <thead>
            <tr><th>Name</th><th>Email</th><th>Phone</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% if (drivers.length === 0) { %>
              <tr><td colspan="5" style="text-align:center; color:#8a8f90;">No drivers yet.</td></tr>
            <% } %>
            <% drivers.forEach(d => { %>
              <tr>
                <td><%= d.name %></td>
                <td><%= d.email %></td>
                <td><%= d.phone || '—' %></td>
                <td>
                  <form method="POST" action="/main-admin/settings/drivers/<%= d.id %>/status" style="display:inline;">
                    <select name="status" onchange="this.form.submit()">
                      <% DRIVER_STATUS_OPTIONS.forEach(s => { %>
                        <option value="<%= s %>" <%= d.status === s ? 'selected' : '' %>><%= s %></option>
                      <% }) %>
                    </select>
                  </form>
                </td>
                <td>
                  <form method="POST" action="/main-admin/settings/drivers/<%= d.id %>/delete" style="margin:0;" onsubmit="return confirm('Remove this driver?');">
                    <button type="submit" class="btn btn-outline btn-sm">Remove</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-card">
      <h3>+ Add Driver</h3>
      <form method="POST" action="/main-admin/settings/drivers" class="form-grid">
        <div class="form-group"><label>Name</label><input type="text" name="name" required></div>
        <div class="form-group"><label>Email (login)</label><input type="email" name="email" required></div>
        <div class="form-group"><label>Phone</label><input type="text" name="phone"></div>
        <div class="form-group"><label>Password</label><input type="text" name="password" placeholder="Leave blank for ChangeMe123!"></div>
        <div class="form-group"><button class="btn btn-sm" type="submit">+ Add Driver</button></div>
      </form>
    </div>
  </div>
</div>
</body>
</html>
