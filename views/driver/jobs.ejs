<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Jobs — SiteGuard Driver</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="driver-shell">
  <div class="driver-topbar">
    <span class="brand">SiteGuard</span>
    <form method="POST" action="/driver/logout" style="margin:0;">
      <button type="submit">Log out (<%= driverName %>)</button>
    </form>
  </div>

  <div class="driver-main">
    <div class="driver-card" style="padding:0;">
      <% if (jobs.length === 0) { %>
        <p style="padding:16px; color:#8a8f90;">No jobs assigned yet.</p>
      <% } %>
      <% jobs.forEach(j => { %>
        <a class="driver-job-item" href="/driver/jobs/<%= j.id %>">
          <div class="job-title"><%= j.order_number %> — <%= j.client_company || j.client_name %></div>
          <div class="job-meta"><%= j.date_from || '—' %> → <%= j.date_to || '—' %></div>
          <div class="job-meta"><span class="badge badge-<%= j.driver_app_status === 'Blocked' ? 'cancelled' : 'confirmed' %>"><%= j.driver_app_status %></span></div>
        </a>
      <% }) %>
    </div>
  </div>
</div>
</body>
</html>
